rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Phase 4: Validation Blueprints
    function isValidUserProfile(data) {
      return data.keys().hasAll(['name', 'email', 'totalBalance', 'monthlyAllowance']) &&
             data.name is string && data.email is string && data.totalBalance is number && data.monthlyAllowance is number &&
             (!data.keys().hasAny(['minBalanceThreshold']) || data.minBalanceThreshold is number) &&
             (!data.keys().hasAny(['dailySpendLimit']) || data.dailySpendLimit is number) &&
             (!data.keys().hasAny(['isLowBalanceEnabled']) || data.isLowBalanceEnabled is bool) &&
             (!data.keys().hasAny(['isDailySpendEnabled']) || data.isDailySpendEnabled is bool);
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['amount', 'category', 'type', 'description', 'date']) &&
             data.amount is number && data.amount > 0 &&
             data.category is string && data.category.size() < 50 &&
             data.type in ['expense', 'earning', 'saving'] &&
             data.description is string && data.description.size() < 200 &&
             data.date is string;
    }

    function isValidGoal(data) {
      return data.keys().hasAll(['title', 'targetAmount', 'currentAmount']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.targetAmount is number && data.targetAmount > 0 &&
             data.currentAmount is number && data.currentAmount >= 0;
    }

    function isValidSplitBill(data) {
      return data.keys().hasAll(['amount', 'description', 'date', 'roommates', 'payerId']) &&
             data.amount is number &&
             data.description is string &&
             data.date is string &&
             data.roommates is list &&
             data.payerId == (data.keys().hasAny(['payerId']) ? data.payerId : request.auth.uid); // Fallback for various contexts
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['type', 'title', 'message', 'date', 'isRead']) &&
             data.type in ['split', 'alert', 'info', 'critical'] &&
             data.title is string && data.title.size() < 100 &&
             data.message is string && data.message.size() < 500 &&
             data.date is string &&
             data.isRead is bool;
    }

    // Rules for Collections
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isSignedIn() && request.query.limit <= 1; // Used in query(collection(db, 'users'), where('email', '==', email))
      allow create: if isOwner(userId) && isValidUserProfile(incoming()) && incoming().email == request.auth.token.email;
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) && 
                    incoming().email == existing().email && // Email is immutable
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'totalBalance', 'monthlyAllowance', 'avatar', 'onboarded', 'updatedAt', 'dateOfBirth', 'minBalanceThreshold', 'dailySpendLimit', 'isLowBalanceEnabled', 'isDailySpendEnabled', 'streakCount', 'lastActiveDate', 'badges']);

      match /transactions/{transactionId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTransaction(incoming()) && isValidId(transactionId);
        allow update: if false; // Transactions are immutable in this flow for audit safety
        allow delete: if isOwner(userId);
      }

      match /goals/{goalId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidGoal(incoming()) && isValidId(goalId);
        allow update: if isOwner(userId) && isValidGoal(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'targetAmount', 'currentAmount', 'icon', 'color', 'deadline']);
        allow delete: if isOwner(userId);
      }

      match /splitBills/{billId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSplitBill(incoming()) && isValidId(billId);
        allow update: if isOwner(userId) && isValidSplitBill(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['roommates', 'description', 'amount']);
        allow delete: if isOwner(userId);
      }

      match /notifications/{notificationId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        // Allow other users to create notifications for this user (e.g. for split requests)
        allow create: if isSignedIn() && isValidNotification(incoming()) && isValidId(notificationId);
        allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
        allow delete: if isOwner(userId);
      }
    }

    match /global_splits/{splitId} {
      // Users can see global splits they are involved in
      allow list, get: if isSignedIn() && (
        resource.data.payerId == request.auth.uid || 
        resource.data.roommates.any(r, r.email == request.auth.token.email)
      );
      // Only the payer can create/update
      allow create: if isSignedIn() && incoming().payerId == request.auth.uid && isValidSplitBill(incoming());
      allow update: if isSignedIn() && existing().payerId == request.auth.uid && isValidSplitBill(incoming());
      allow delete: if isSignedIn() && existing().payerId == request.auth.uid;
    }
  }
}
