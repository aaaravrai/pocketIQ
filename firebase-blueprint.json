{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Core user information and financial settings.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatar": { "type": "string" },
        "dateOfBirth": { "type": "string", "format": "date" },
        "totalBalance": { "type": "number" },
        "monthlyAllowance": { "type": "number" },
        "onboarded": { "type": "boolean" },
        "minBalanceThreshold": { "type": "number" },
        "dailySpendLimit": { "type": "number" },
        "isLowBalanceEnabled": { "type": "boolean" },
        "isDailySpendEnabled": { "type": "boolean" },
        "streakCount": { "type": "number" },
        "lastActiveDate": { "type": "string" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "educationROI": {
          "type": "object",
          "properties": {
            "semesterFees": { "type": "number" },
            "booksCost": { "type": "number" },
            "otherAcademicCosts": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "totalBalance", "monthlyAllowance"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial record of income, expense, or savings.",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["expense", "earning", "saving"] },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["amount", "category", "type", "description", "date"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A financial savings target.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "deadline": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "targetAmount", "currentAmount"]
    },
    "SplitBill": {
      "title": "Split Bill",
      "description": "A shared expense split among roommates.",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "payerId": { "type": "string" },
        "roommates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "email": { "type": "string", "format": "email" },
              "amount": { "type": "number" },
              "settled": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["amount", "description", "date", "roommates", "payerId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "Top-level user profiles."
    },
    "users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Subcollection of user transactions."
    },
    "users/{userId}/goals/{goalId}": {
      "schema": "Goal",
      "description": "Subcollection of user savings goals."
    },
    "users/{userId}/splitBills/{billId}": {
      "schema": "SplitBill",
      "description": "Subcollection of shared expenses."
    }
  }
}
